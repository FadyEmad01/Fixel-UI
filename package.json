{
  "name": "fixel-ui",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "generate:registry": "tsx src/scripts/generate-registry.ts",
    "generate:registry:verbose": "tsx src/scripts/generate-registry.ts --verbose",
    "validate:registry": "tsx src/scripts/generate-registry.ts validate public/r/registry.json",
    "registry:info": "tsx src/scripts/generate-registry.ts info",
    "generate:markdown": "tsx src/scripts/generate-markdown.ts src/content/components/",
    "generate:category-slugs": "tsx src/scripts/generate-category-slugs.ts",
    "generate:rss": "tsx src/scripts/generate-rss.ts",
    "build": "next build",
    "build:for-build-registry": "npm run generate:registry && npm run generate:category-slugs && npm run generate:markdown && npm run generate:rss && next build",
    "generate": "npm run generate:registry && npm run generate:category-slugs && npm run generate:markdown",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write"
  },
