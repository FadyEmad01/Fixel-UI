      "target": "components/form-layout-03.tsx",
      "content": "import { Button } from \"@/components/ui/button\";\r\nimport { Checkbox } from \"@/components/ui/checkbox\";\r\nimport { Field, FieldDescription, FieldLabel } from \"@/components/ui/field\";\r\nimport { Input } from \"@/components/ui/input\";\r\nimport {\r\n  Select,\r\n  SelectContent,\r\n  SelectItem,\r\n  SelectTrigger,\r\n  SelectValue,\r\n} from \"@/components/ui/select\";\r\nimport { Separator } from \"@/components/ui/separator\";\r\nimport { Textarea } from \"@/components/ui/textarea\";\r\n\r\nexport default function FormLayout03() {\r\n  return (\r\n    <div className=\"flex items-center justify-center p-10\">\r\n      <form>\r\n        <div className=\"grid grid-cols-1 gap-10 md:grid-cols-3\">\r\n          <div>\r\n            <h2 className=\"text-balance font-semibold text-foreground dark:text-foreground\">\r\n              Personal information\r\n            </h2>\r\n            <p className=\"text-pretty mt-1 text-sm leading-6 text-muted-foreground dark:text-muted-foreground\">\r\n              Lorem ipsum dolor sit amet, consetetur sadipscing elitr.\r\n            </p>\r\n          </div>\r\n          <div className=\"sm:max-w-3xl md:col-span-2\">\r\n            <div className=\"grid grid-cols-1 gap-4 sm:grid-cols-6\">\r\n              <div className=\"col-span-full sm:col-span-3\">\r\n                <Field className=\"gap-2\">\r\n                  <FieldLabel htmlFor=\"first-name\">First name</FieldLabel>\r\n                  <Input\r\n                    type=\"text\"\r\n                    id=\"first-name\"\r\n                    name=\"first-name\"\r\n                    autoComplete=\"given-name\"\r\n                    placeholder=\"Emma\"\r\n                  />\r\n                </Field>\r\n              </div>\r\n              <div className=\"col-span-full sm:col-span-3\">\r\n                <Field className=\"gap-2\">\r\n                  <FieldLabel htmlFor=\"last-name\">Last name</FieldLabel>\r\n                  <Input\r\n                    type=\"text\"\r\n                    id=\"last-name\"\r\n                    name=\"last-name\"\r\n                    autoComplete=\"family-name\"\r\n                    placeholder=\"Crown\"\r\n                  />\r\n                </Field>\r\n              </div>\r\n              <div className=\"col-span-full\">\r\n                <Field className=\"gap-2\">\r\n                  <FieldLabel htmlFor=\"email\">Email</FieldLabel>\r\n                  <Input\r\n                    type=\"email\"\r\n                    id=\"email\"\r\n                    name=\"email\"\r\n                    autoComplete=\"email\"\r\n                    placeholder=\"emma@company.com\"\r\n                  />\r\n                </Field>\r\n              </div>\r\n              <div className=\"col-span-full sm:col-span-3\">\r\n                <Field className=\"gap-2\">\r\n                  <FieldLabel htmlFor=\"birthyear\">Birth year</FieldLabel>\r\n                  <Input\r\n                    type=\"number\"\r\n                    id=\"birthyear\"\r\n                    name=\"year\"\r\n                    placeholder=\"1990\"\r\n                  />\r\n                </Field>\r\n              </div>\r\n              <div className=\"col-span-full sm:col-span-3\">\r\n                <Field className=\"gap-2\">\r\n                  <FieldLabel htmlFor=\"role\">Role</FieldLabel>\r\n                  <Input\r\n                    type=\"text\"\r\n                    id=\"role\"\r\n                    name=\"role\"\r\n                    placeholder=\"Senior Manager\"\r\n                    disabled\r\n                  />\r\n                  <FieldDescription>\r\n                    Roles can only be changed by system admin.\r\n                  </FieldDescription>\r\n                </Field>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <Separator className=\"my-8\" />\r\n        <div className=\"grid grid-cols-1 gap-10 md:grid-cols-3\">\r\n          <div>\r\n            <h2 className=\"text-balance font-semibold text-foreground dark:text-foreground\">\r\n              Workspace settings\r\n            </h2>\r\n            <p className=\"text-pretty mt-1 text-sm leading-6 text-muted-foreground dark:text-muted-foreground\">\r\n              Lorem ipsum dolor sit amet, consetetur sadipscing elitr.\r\n            </p>\r\n          </div>\r\n          <div className=\"sm:max-w-3xl md:col-span-2\">\r\n            <div className=\"grid grid-cols-1 gap-4 sm:grid-cols-6\">\r\n              <div className=\"col-span-full sm:col-span-3\">\r\n                <Field className=\"gap-2\">\r\n                  <FieldLabel htmlFor=\"workspace-name\">Workspace name</FieldLabel>\r\n                  <Input\r\n                    type=\"text\"\r\n                    id=\"workspace-name\"\r\n                    name=\"workspace-name\"\r\n                    placeholder=\"Test workspace\"\r\n                  />\r\n                </Field>\r\n              </div>\r\n              <div className=\"col-span-full sm:col-span-3\">\r\n                <Field className=\"gap-2\">\r\n                  <FieldLabel htmlFor=\"visibility\">Visibility</FieldLabel>\r\n                  <Select name=\"visibility\" defaultValue=\"private\">\r\n                    <SelectTrigger id=\"visibility\">\r\n                      <SelectValue placeholder=\"Select visibility\" />\r\n                    </SelectTrigger>\r\n                    <SelectContent>\r\n                      <SelectItem value=\"public\">Public</SelectItem>\r\n                      <SelectItem value=\"private\">Private</SelectItem>\r\n                    </SelectContent>\r\n                  </Select>\r\n                </Field>\r\n              </div>\r\n              <div className=\"col-span-full\">\r\n                <Field className=\"gap-2\">\r\n                  <FieldLabel htmlFor=\"workspace-description\">\r\n                    Workspace description\r\n                  </FieldLabel>\r\n                  <Textarea\r\n                    id=\"workspace-description\"\r\n                    name=\"workspace-description\"\r\n                    rows={4}\r\n                  />\r\n                  <FieldDescription>\r\n                    Note: description provided will not be displayed externally.\r\n                  </FieldDescription>\r\n                </Field>\r\n              </div>\r\n            </div>\r\n          </div>\r\n        </div>\r\n        <Separator className=\"my-8\" />\r\n        <div className=\"grid grid-cols-1 gap-10 md:grid-cols-3\">\r\n          <div>\r\n            <h2 className=\"text-balance font-semibold text-foreground dark:text-foreground\">\r\n              Notification settings\r\n            </h2>\r\n            <p className=\"text-pretty mt-1 text-sm leading-6 text-muted-foreground dark:text-muted-foreground\">\r\n              Lorem ipsum dolor sit amet, consetetur sadipscing elitr.\r\n            </p>\r\n          </div>\r\n          <div className=\"sm:max-w-3xl md:col-span-2\">\r\n            <fieldset>\r\n              <legend className=\"text-sm font-medium text-foreground dark:text-foreground\">\r\n                Team\r\n              </legend>\r\n              <FieldDescription className=\"mt-1 leading-6\">\r\n                Configure the types of team alerts you want to receive.\r\n              </FieldDescription>\r\n              <div className=\"mt-2\">\r\n                <div className=\"flex items-center gap-x-3 py-1\">\r\n                  <Checkbox\r\n                    id=\"team-requests\"\r\n                    name=\"team-requests\"\r\n                    defaultChecked\r\n                  />\r\n                  <FieldLabel htmlFor=\"team-requests\" className=\"font-normal\">\r\n                    Team join requests\r\n                  </FieldLabel>\r\n                </div>\r\n                <div className=\"flex items-center gap-x-3 py-1\">\r\n                  <Checkbox\r\n                    id=\"team-activity-digest\"\r\n                    name=\"team-activity-digest\"\r\n                  />\r\n                  <FieldLabel\r\n                    htmlFor=\"team-activity-digest\"\r\n                    className=\"font-normal\"\r\n                  >\r\n                    Weekly team activity digest\r\n                  </FieldLabel>\r\n                </div>\r\n              </div>\r\n            </fieldset>\r\n            <fieldset className=\"mt-6\">\r\n              <legend className=\"text-sm font-medium text-foreground dark:text-foreground\">\r\n                Usage\r\n              </legend>\r\n              <FieldDescription className=\"mt-1 leading-6\">\r\n                Configure the types of usage alerts you want to receive.\r\n              </FieldDescription>\r\n              <div className=\"mt-2\">\r\n                <div className=\"flex items-center gap-x-3 py-1\">\r\n                  <Checkbox id=\"api-requests\" name=\"api-requests\" />\r\n                  <FieldLabel htmlFor=\"api-requests\" className=\"font-normal\">\r\n                    API requests\r\n                  </FieldLabel>\r\n                </div>\r\n                <div className=\"flex items-center gap-x-3 py-1\">\r\n                  <Checkbox\r\n                    id=\"workspace-execution\"\r\n                    name=\"workspace-execution\"\r\n                  />\r\n                  <FieldLabel\r\n                    htmlFor=\"workspace-execution\"\r\n                    className=\"font-normal\"\r\n                  >\r\n                    Workspace loading times\r\n                  </FieldLabel>\r\n                </div>\r\n                <div className=\"flex items-center gap-x-3 py-1\">\r\n                  <Checkbox\r\n                    id=\"query-caching\"\r\n                    name=\"query-caching\"\r\n                    defaultChecked\r\n                  />\r\n                  <FieldLabel htmlFor=\"query-caching\" className=\"font-normal\">\r\n                    Query caching\r\n                  </FieldLabel>\r\n                </div>\r\n                <div className=\"flex items-center gap-x-3 py-1\">\r\n                  <Checkbox id=\"storage\" name=\"storage\" defaultChecked />\r\n                  <FieldLabel htmlFor=\"storage\" className=\"font-normal\">\r\n                    Storage\r\n                  </FieldLabel>\r\n                </div>\r\n              </div>\r\n            </fieldset>\r\n          </div>\r\n        </div>\r\n        <Separator className=\"my-8\" />\r\n        <div className=\"flex items-center justify-end space-x-4\">\r\n          <Button type=\"button\" variant=\"outline\" className=\"whitespace-nowrap\">\r\n            Go back\r\n          </Button>\r\n          <Button type=\"submit\" className=\"whitespace-nowrap\">\r\n            Save settings\r\n          </Button>\r\n        </div>\r\n      </form>\r\n    </div>\r\n  );\r\n}\r\n"
    }
  ],
